# ============================================================
# CONFIGURAÇÃO DE AMBIENTE - ATOMICAMENTE
# ============================================================
# IMPORTANTE: Copie este arquivo para .env e preencha com seus dados reais
# NUNCA commite o arquivo .env no Git - ele contém senhas confidenciais!
# ============================================================

# ======= BASE DE DADOS =======
DB_HOST=localhost
DB_NAME=atomicamente_db
DB_USER=seu_usuario_db
DB_PASS=sua_senha_super_segura
DB_CHARSET=utf8mb4

# ======= AMBIENTE =======
# Valores: development, production
APP_ENV=development

# ======= SEGURANÇA =======
# Coloque 'true' em produção
FORCE_HTTPS=false

# ======= ADMIN EMAILS =======
# Emails dos administradores separados por vírgula
ADMIN_EMAILS=seu_email@exemplo.com,outro_admin@exemplo.com
