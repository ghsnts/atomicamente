# ============================================================
# ARQUIVO .gitignore - Proteção de Dados Sensíveis
# ============================================================

# Configurações sensíveis (NUNCA commitar senhas!)
config.php
.env
.env.local
.env.*.local

# Ficheiros do Sistema Operativo
Thumbs.db
.DS_Store

# Pastas de IDEs / Editores de Código
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Ficheiros de Log
*.log
logs/

# Cache e arquivos temporários
.cache/
tmp/
temp/

# Node modules (se usar npm/webpack)
node_modules/
package-lock.json

# Composer (se usar PHP Composer)
vendor/
composer.lock

# Banco de dados local
*.sqlite
*.db

# Arquivos de backup
*.bak
*.backup
*.sql.backup

# IDE específicas
.netbeans/
.eclipse/
.sublime-project
.sublime-workspace
